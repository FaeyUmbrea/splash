{
	"compilerOptions": {
		"target": "ES2022",
		"module": "esnext",
		"moduleResolution": "Bundler",

		"types": ["fvtt-types"],
		"allowImportingTsExtensions": true,
		"strict": false,
		"strictNullChecks": true,
		"noEmit": true,
		"sourceMap": true,
		"forceConsistentCasingInFileNames": true,
		"isolatedModules": true,

		"verbatimModuleSyntax": true,
		"skipLibCheck": true
	},

	"include": ["src/**/*"],
	"exclude": ["node_modules/*"]
}
